# Database
DATABASE_URL=postgres://studio:studio@localhost:5434/studio_reservation

# Auth (hash generated by `pnpm tsx scripts/hash-password.ts <password>`)
AUTH_PASSWORD_HASH=
AUTH_COOKIE_SECRET=replace-with-random-32-byte-hex

# App
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Seoul

# Google Calendar OAuth (Google Cloud Console에서 생성)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
